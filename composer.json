{
    "name": "Libxa/framework",
    "description": "LibxaFrame core framework — Foundation, Router, Atlas ORM, Blade-X, Reactive, Modules, Frontend Adapters.",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.3",
        "psr/container": "^2.0",
        "psr/http-message": "^2.0",
        "psr/http-server-handler": "^1.0",
        "psr/log": "^3.0",
        "workerman/workerman": "^4.1",
        "symfony/console": "^7.0",
        "vlucas/phpdotenv": "^5.6",
        "nikic/php-parser": "^5.7"
    },
    "autoload": {
        "psr-4": {
            "Libxa\\": "src/"
        },
        "files": [
            "src/Support/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0",
        "phpstan/phpstan": "^1.10",
        "squizlabs/php_codesniffer": "^3.9"
    },
    "extra": {
        "Libxa": {
            "providers": []
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
